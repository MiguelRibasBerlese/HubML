# ─── Banco ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hubml:hubml@localhost:5433/hubml?schema=public"

# ─── Servidor ───────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info                       # trace|debug|info|warn|error
NODE_ENV=development

# ─── Mercado Livre — app do DevCenter (D3: já existe) ───────────────────────
ML_APP_ID=""                         # client_id da aplicação
ML_CLIENT_SECRET=""                  # client secret
ML_REDIRECT_URI="http://localhost:3000/auth/ml/callback"  # EXATAMENTE igual ao cadastrado no app
ML_PKCE_ENABLED=false                # true se o app tiver PKCE habilitado (aí vira obrigatório)

# ML base URLs (raramente mudam — defaults já corretos)
ML_API_BASE_URL="https://api.mercadolibre.com"
ML_AUTH_BASE_URL="https://auth.mercadolivre.com.br"

# ─── Cliente HTTP ───────────────────────────────────────────────────────────
ML_HTTP_TIMEOUT_MS=15000
ML_HTTP_MAX_RETRIES=4
ML_HTTP_MAX_CONCURRENCY=5

# ─── Worker de jobs ─────────────────────────────────────────────────────────
JOB_POLL_INTERVAL_MS=1000
JOB_BATCH_SIZE=5

# ─── Reconciliação / sync (M8) ──────────────────────────────────────────────
RECONCILE_INTERVAL_MINUTES=60

# ─── NF-e fallback Focus NFe (D2 — trilho B, opcional) ──────────────────────
FOCUS_NFE_TOKEN=""
FOCUS_NFE_BASE_URL="https://api.focusnfe.com.br"

MOOVIN_IMPORT_FILE_PATH=data/produtos_moovin.xlsx